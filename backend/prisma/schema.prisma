generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(uuid())
  loginId                String                  @unique
  passwordHash           String
  role                   String
  status                 String                  @default("pending")
  createdAt              DateTime                @default(now())
  candidateVerifications CandidateVerification[]
  organizationProfile    OrganizationProfile?
  policeProfile          PoliceProfile?
  supportTickets         SupportTicket[]
  auditLogs              SystemAuditLog[]

  @@index([role])
}

model SystemAuditLog {
  id        Int      @id @default(autoincrement())
  userId    String
  action    String
  ipAddress String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PoliceProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  name           String
  badgeId        String?
  rank           String?
  empId          String?
  department     String?
  wing           String?
  jurisdiction   String?
  joiningDate    String?
  email          String?
  mobile         String?
  altPhone       String?
  station        String?
  district       String?
  state          String?
  country        String?
  clearanceLevel String?
  docsMediaIds   Int[]    // -> Media.id[]
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OrganizationProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  orgName             String
  orgType             String
  parentOrg           String?
  department          String?
  jurisdiction        String?
  country             String
  state               String
  district            String
  city                String
  address             String
  pinCode             String
  officialEmail       String
  officialPhone       String
  altPhone            String?
  website             String?
  adminName           String
  designation         String
  empId               String
  adminEmail          String
  mobile              String
  authLetterMediaId      Int?    // -> Media.id
  govCertMediaId         Int?    // -> Media.id
  supportingDocsMediaIds Int[]   // -> Media.id[]
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CandidateVerification {
  id             String   @id @default(uuid())
  organizationId String
  orgName        String
  orgType        String
  role           String
  candidateName  String
  dob            DateTime
  fatherName     String?
  phone          String
  consent        Boolean
  aadharNumber   String?
  address        String?
  candidateMediaId Int?    // -> Media.id
  consentMediaId   Int?    // -> Media.id
  status         String   @default("pending")
  policeFeedback String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization   User     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status])
}

model SupportTicket {
  id             String          @id @default(uuid())
  ticketNumber   String          @unique @default(cuid())
  organizationId String
  subject        String
  category       String
  priority       String          @default("Medium")
  reference      String?
  status         String          @default("Open")
  assignee       String?         @default("Unassigned")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   User            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages       TicketMessage[]
}

model TicketMessage {
  id         String        @id @default(uuid())
  ticketId   String
  senderName String
  senderRole String
  text       String
  createdAt  DateTime      @default(now())
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

/// Central registry of every file stored in MinIO. Other tables reference a row
/// here by its `id` (stored in their document columns) instead of holding a raw
/// object key or URL. Signed URLs are generated on demand from `objectKey` and
/// are never persisted.
model Media {
  id           Int      @id @default(autoincrement())
  bucketName   String
  objectKey    String   @unique
  originalName String
  fileType     String?
  fileSize     Int?
  category     String? // 'candidate_image' | 'consent' | 'auth_letter' | 'gov_cert' | 'supporting_doc' | 'police_doc'
  uploadedBy   String?
  createdAt    DateTime @default(now())

  @@index([category])
}

model EPettyCase {
  id             String   @id @default(uuid())
  caseNumber     String   @unique
  offenderName   String
  alias          String?
  age            Int?
  fatherName     String?
  phone          String
  email          String?
  address        String?
  policeStation  String?
  district       String?
  incidentDate   String?
  offenceType    String?
  penaltyAmount  Float?   @default(500.0)
  disposalStatus String?  @default("Fine Paid")
  riskTier       String   @default("Orange")
  createdAt      DateTime @default(now())

  @@index([riskTier])
}
