# Use either DATABASE_URL or the split POSTGRES_* settings below.
DATABASE_URL="postgresql://username:password@localhost:5432/ssor"

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ssor
POSTGRES_USER=username
POSTGRES_PASSWORD=password

PORT=5000
PORT_RETRY_LIMIT=20
NODE_ENV=development
AUTO_DB_PUSH=false
FRONTEND_URL="http://localhost:3000"
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
JWT_SECRET="replace-with-a-long-random-secret"

EPETTY_API_URL="https://example.gov/api/epettyCase/personDetails"
EPETTY_BASIC_AUTH="Basic base64-clientid-clientsecret"
GEMINI_API_KEY="replace-with-gemini-api-key"

# ePrisons API (police map alerts)
PRIVATE_KEY=""
EPRISONS_TOKEN_URL="https://eprisons.nic.in/ePrisonsAPI/api/Token"
EPRISONS_RELEASES_URL="https://eprisons.nic.in/eprisonsapi/api/ePrisons/PrisonerAdmissionReleaseDetails"
EPRISONS_USER_ID=""
EPRISONS_PASSWORD=""
