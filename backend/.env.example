# PostgreSQL Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ssor
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password

# Application Settings
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key_here

# ePetty API Integration
EPETTY_API_URL=http://your_epetty_api_url/api/epettyCase/personDetails
EPETTY_BASIC_AUTH=Basic your_base64_encoded_credentials

# AI Integrations
GEMINI_API_KEY=your_gemini_api_key

# ePrisons Integration
PRIVATE_KEY=your_eprisons_private_key
EPRISONS_TOKEN_URL=https://eprisons.nic.in/ePrisonsAPI/api/Token
EPRISONS_RELEASES_URL=https://eprisons.nic.in/eprisonsapi/api/ePrisons/PrisonerAdmissionReleaseDetails
EPRISONS_USER_ID=your_eprisons_user_id
EPRISONS_PASSWORD=your_eprisons_password

# MinIO Object Storage (document uploads)
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ssor-documents
# Public, browser-reachable MinIO host used ONLY to sign presigned URLs.
# REQUIRED in production (browsers cannot reach the internal MINIO_ENDPOINT).
# Leave blank in local dev to reuse MINIO_ENDPOINT.
MINIO_PUBLIC_ENDPOINT=
MINIO_PUBLIC_PORT=
MINIO_PUBLIC_USE_SSL=

# Logging: error | warn | info | debug
LOG_LEVEL=info
